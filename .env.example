# Database
DB_URL=jdbc:mysql://localhost:3306/campusride_db?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=password

# JWT
JWT_SECRET=campusride-super-secret-key-for-jwt-token-generation-2024-minimum-256-bits
JWT_EXPIRATION=86400000

# Google OAuth (get from Google Cloud Console)
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Server
SERVER_PORT=8080
